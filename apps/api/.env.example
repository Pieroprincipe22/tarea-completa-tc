# ============================================
# TC Mantenimiento - API · Variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# ============================================

# --- Base de datos (PostgreSQL) ---
# En local apunta al Postgres del docker-compose (puerto 5433).
DATABASE_URL="postgresql://USUARIO:PASSWORD@localhost:5433/NOMBRE_BD?schema=public"

# --- JWT (autenticación) ---
# OBLIGATORIO. La API no arranca sin esto.
# Genera uno fuerte con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=""
JWT_ACCESS_EXPIRES_IN="12h"

# --- Almacenamiento de archivos (S3 / MinIO) ---
# S3_ACCESS_KEY y S3_SECRET_KEY son OBLIGATORIAS (la API no arranca sin ellas).
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="tc"
# Caducidad de las URLs firmadas, en segundos (por defecto 3600 = 1h).
S3_PRESIGN_EXP_SECONDS="3600"

# --- Panel de administración de plataforma ---
# Clave para los endpoints /admin. OBLIGATORIA.
ADMIN_KEY=""

# --- CORS ---
# Orígenes permitidos, separados por coma. En producción pon SOLO tu dominio real.
CORS_ORIGINS="http://localhost:3001"

# --- Servidor ---
PORT="3002"
NODE_ENV="development"