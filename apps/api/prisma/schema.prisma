generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TECHNICIAN
}

enum WorkOrderStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceReportStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum MaintenanceItemStatus {
  PENDING
  OK
  FAIL
  NA
}

enum EmergencyRequestStatus {
  OPEN
  DISPATCHED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum AttachmentOwnerType {
  WORK_ORDER
  REPORT
  ASSET
  EMERGENCY_REQUEST
}

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers            Customer[]
  sites                Site[]
  contacts             Contact[]
  assets               Asset[]
  maintenanceTemplates MaintenanceTemplate[]
  maintenanceReports   MaintenanceReport[]
  workOrders           WorkOrder[]
  emergencyRequests    EmergencyRequest[]
  userCompanies        UserCompany[]
  attachments          Attachment[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userCompanies       UserCompany[]
  assignedWorkOrders  WorkOrder[]         @relation("WorkOrderAssignedTo")
  assignedEmergencies EmergencyRequest[]  @relation("EmergencyAssignedTo")
  createdReports      MaintenanceReport[] @relation("ReportCreatedBy")
  completedReports    MaintenanceReport[] @relation("ReportCompletedBy")
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  role      UserRole
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model Customer {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sites              Site[]
  maintenanceReports MaintenanceReport[]
  workOrders         WorkOrder[]
  emergencyRequests  EmergencyRequest[]

  @@index([companyId])
}

model Site {
  id         String   @id @default(uuid())
  companyId  String
  customerId String
  name       String
  address    String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  contacts           Contact[]
  assets             Asset[]
  maintenanceReports MaintenanceReport[]
  workOrders         WorkOrder[]
  emergencyRequests  EmergencyRequest[]

  @@index([companyId])
  @@index([customerId])
}

model Contact {
  id        String   @id @default(uuid())
  companyId String
  siteId    String
  name      String
  email     String?
  phone     String?
  isMain    Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([siteId])
}

model Asset {
  id             String    @id @default(uuid())
  companyId      String
  siteId         String
  name           String
  category       String?
  brand          String?
  model          String?
  serialNumber   String?
  internalCode   String?
  status         String?
  installationAt DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  maintenanceReports MaintenanceReport[]
  workOrders         WorkOrder[]
  emergencyRequests  EmergencyRequest[]
  attachments        Attachment[]

  @@index([companyId])
  @@index([siteId])
}

model MaintenanceTemplate {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  items   MaintenanceTemplateItem[]
  reports MaintenanceReport[]

  @@index([companyId])
}

model MaintenanceTemplateItem {
  id          String   @id @default(uuid())
  templateId  String
  title       String
  description String?
  itemOrder   Int
  valueType   String? // text, number, boolean, select, etc.
  unit        String?
  required    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template MaintenanceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  reportItems MaintenanceReportItem[]

  @@unique([templateId, itemOrder])
  @@index([templateId])
}

model MaintenanceReport {
  id                String                  @id @default(uuid())
  companyId         String
  customerId        String
  siteId            String
  assetId           String
  templateId        String?
  workOrderId       String?
  title             String
  description       String?
  notes             String?
  status            MaintenanceReportStatus @default(DRAFT)
  createdByUserId   String?
  completedByUserId String?
  completedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  site            Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  asset           Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  template        MaintenanceTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  workOrder       WorkOrder?           @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  createdByUser   User?                @relation("ReportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  completedByUser User?                @relation("ReportCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  items       MaintenanceReportItem[]
  attachments Attachment[]

  @@index([companyId])
  @@index([customerId])
  @@index([siteId])
  @@index([assetId])
  @@index([templateId])
  @@index([workOrderId])
  @@index([createdByUserId])
  @@index([completedByUserId])
}

model MaintenanceReportItem {
  id             String                @id @default(uuid())
  reportId       String
  templateItemId String?
  title          String
  description    String?
  itemOrder      Int
  status         MaintenanceItemStatus @default(PENDING)
  value          String?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  report       MaintenanceReport        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  templateItem MaintenanceTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@unique([reportId, itemOrder])
  @@index([reportId])
  @@index([templateItemId])
}

model WorkOrder {
  id               String            @id @default(uuid())
  companyId        String
  customerId       String
  siteId           String
  assetId          String?
  assignedToUserId String?
  title            String
  description      String?
  status           WorkOrderStatus   @default(OPEN)
  priority         WorkOrderPriority @default(MEDIUM)
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  asset      Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("WorkOrderAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  reports     MaintenanceReport[]
  attachments Attachment[]

  @@index([companyId])
  @@index([customerId])
  @@index([siteId])
  @@index([assetId])
  @@index([assignedToUserId])
  @@index([status])
}

model EmergencyRequest {
  id               String                 @id @default(uuid())
  companyId        String
  customerId       String
  siteId           String
  assetId          String?
  assignedToUserId String?
  title            String
  description      String?
  status           EmergencyRequestStatus @default(OPEN)
  priority         WorkOrderPriority      @default(URGENT)
  requestedByName  String?
  requestedByPhone String?
  requestedAt      DateTime               @default(now())
  dispatchedAt     DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  asset      Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("EmergencyAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  attachments Attachment[]

  @@index([companyId])
  @@index([customerId])
  @@index([siteId])
  @@index([assetId])
  @@index([assignedToUserId])
  @@index([status])
}

model Attachment {
  id                 String              @id @default(uuid())
  companyId          String
  ownerType          AttachmentOwnerType
  ownerId            String
  fileName           String
  fileUrl            String
  mimeType           String?
  sizeBytes          Int?
  assetId            String?
  reportId           String?
  workOrderId        String?
  emergencyRequestId String?
  createdAt          DateTime            @default(now())

  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  asset            Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  report           MaintenanceReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  workOrder        WorkOrder?         @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  emergencyRequest EmergencyRequest?  @relation(fields: [emergencyRequestId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([ownerType, ownerId])
  @@index([assetId])
  @@index([reportId])
  @@index([workOrderId])
  @@index([emergencyRequestId])
}
