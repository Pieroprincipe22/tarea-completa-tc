generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TECHNICIAN
}

enum WorkOrderStatus {
  OPEN
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceItemType {
  TEXT
  LONG_TEXT
  TEXTAREA
  NUMBER
  BOOLEAN
  DATE
  CHECKBOX
  CHECKLIST
  PHOTO
  SIGNATURE
}

enum MaintenanceReportStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  customers            Customer[]
  assets               Asset[]
  workOrders           WorkOrder[]
  maintenanceTemplates MaintenanceTemplate[]
  maintenanceReports   MaintenanceReport[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdWorkOrders  WorkOrder[] @relation("WorkOrderCreatedBy")
  assignedWorkOrders WorkOrder[] @relation("WorkOrderAssignedTechnician")

  createdMaintenanceReports   MaintenanceReport[] @relation("MaintenanceReportCreatedBy")
  assignedMaintenanceReports  MaintenanceReport[] @relation("MaintenanceReportAssignedTechnician")
  submittedMaintenanceReports MaintenanceReport[] @relation("MaintenanceReportSubmittedBy")
  reviewedMaintenanceReports  MaintenanceReport[] @relation("MaintenanceReportReviewedBy")

  @@index([companyId])
  @@index([companyId, role])
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets     Asset[]
  workOrders WorkOrder[]

  @@index([companyId, name])
}

model Asset {
  id           String   @id @default(cuid())
  companyId    String
  customerId   String?
  name         String
  code         String?
  brand        String?
  model        String?
  serialNumber String?
  location     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  workOrders WorkOrder[]

  @@index([companyId, name])
  @@index([customerId])
}

model MaintenanceTemplate {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items              MaintenanceTemplateItem[]
  workOrders         WorkOrder[]
  maintenanceReports MaintenanceReport[]

  @@index([companyId, isActive])
}

model MaintenanceTemplateItem {
  id          String              @id @default(cuid())
  templateId  String
  label       String
  type        MaintenanceItemType
  required    Boolean             @default(false)
  sortOrder   Int                 @default(0)
  helpText    String?
  placeholder String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  template    MaintenanceTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  reportItems MaintenanceReportItem[]

  @@index([templateId, sortOrder])
}

model WorkOrder {
  id                    String            @id @default(cuid())
  companyId             String
  customerId            String?
  assetId               String?
  createdById           String?
  assignedTechnicianId  String?
  maintenanceTemplateId String?
  code                  String?
  title                 String
  description           String?
  status                WorkOrderStatus   @default(OPEN)
  priority              WorkOrderPriority @default(MEDIUM)
  scheduledFor          DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer            Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  asset               Asset?               @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdBy           User?                @relation("WorkOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTechnician  User?                @relation("WorkOrderAssignedTechnician", fields: [assignedTechnicianId], references: [id], onDelete: SetNull)
  maintenanceTemplate MaintenanceTemplate? @relation(fields: [maintenanceTemplateId], references: [id], onDelete: SetNull)
  maintenanceReport   MaintenanceReport?

  @@index([companyId, status])
  @@index([assignedTechnicianId, status])
  @@index([customerId])
  @@index([assetId])
  @@index([maintenanceTemplateId])
  @@index([companyId, code])
}

model MaintenanceReport {
  id                   String                  @id @default(cuid())
  companyId            String
  workOrderId          String                  @unique
  templateId           String?
  createdById          String?
  assignedTechnicianId String?
  submittedById        String?
  reviewedById         String?
  status               MaintenanceReportStatus @default(DRAFT)

  summary         String?
  diagnosis       String?
  workPerformed   String?
  recommendations String?
  observations    String?
  technicianNotes String?
  reviewNotes     String?

  laborHours Decimal? @db.Decimal(10, 2)

  assignedAt  DateTime?
  startedAt   DateTime?
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrder          WorkOrder            @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  template           MaintenanceTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy          User?                @relation("MaintenanceReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTechnician User?                @relation("MaintenanceReportAssignedTechnician", fields: [assignedTechnicianId], references: [id], onDelete: SetNull)
  submittedBy        User?                @relation("MaintenanceReportSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy         User?                @relation("MaintenanceReportReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  items     MaintenanceReportItem[]
  materials MaintenanceReportMaterial[]

  @@index([companyId, status])
  @@index([assignedTechnicianId, status])
  @@index([templateId])
}

model MaintenanceReportItem {
  id             String              @id @default(cuid())
  reportId       String
  templateItemId String?
  label          String
  type           MaintenanceItemType
  required       Boolean             @default(false)
  sortOrder      Int                 @default(0)

  valueText    String?
  valueNumber  Float?
  valueBoolean Boolean?
  valueDate    DateTime?
  valueJson    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report       MaintenanceReport        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  templateItem MaintenanceTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@index([reportId, sortOrder])
  @@index([templateItemId])
}

model MaintenanceReportMaterial {
  id          String   @id @default(cuid())
  reportId    String
  name        String
  description String?
  quantity    Float    @default(1)
  unit        String?
  sortOrder   Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  report MaintenanceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, sortOrder])
}
